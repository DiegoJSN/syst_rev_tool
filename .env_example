# Copy this file and rename the copy to: .env
# Edit .env and replace the placeholders.

# ------------------------------------------------------------
# DATABASE CONFIG
# ------------------------------------------------------------

# {username} → your PostgreSQL username (e.g., review_user)
# {password} → the user password
# {device_ip} → the device IP of the server (e.g., 100.x.x.x)
# {device_name} -> the device name of the server (e.g., syst-rev-server)
# {db_name} → your database name (e.g., systrev_db)

# Use ONE of the options below for DATABASE_URL.

# OPTION A (SERVER machine only): local database on the same PC
# Use this if you run python app.py on the same machine where PostgreSQL is installed.
# DATABASE_URL="postgresql://{username}:{password}@127.0.0.1:5432/{db_name}"

# OPTION B (REVIEWERS / remote clients): connect to the server over Tailscale
# Recommended: {device_name] -> use the full MagicDNS name (FQDN), not the short name.
# DATABASE_URL="postgresql://{username}:{password}@syst-rev-server.tail1649d7.ts.net:5432/{db_name}"

# Alternative: {device_ip} -> use the Tailscale IPv4 of the server (100.x.y.z)
# DATABASE_URL="postgresql://{username}:{password}@100.104.194.28:5432/{db_name}"

DATABASE_URL="postgresql://{username}:{password}@{device_ip OR device_name}:5432/{db_name}"
