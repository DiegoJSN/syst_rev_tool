# Copy/duplicate this file and rename the copy to: .env
# Edit .env and replace the placeholders:
# {username} → your PostgreSQL username (e.g., review_user)
# {password} → the user password
# {device_ip} → the device IP of the server (e.g., 100.x.x.x)
# {device_name} -> the device name of the server (e.g., syst-rev-server)
# {db_name} → your database name (e.g., systrev_db)

# Example using the device_ip:
# DATABASE_URL="postgresql://review_user:your_password@100.104.194.28:5432/db"

# Example using the device_name:
# DATABASE_URL="postgresql://review_user:your_password@syst-rev-server:5432/db"

DATABASE_URL="postgresql://{username}:{password}@{device_ip OR device_name}:5432/{db_name}"

# Delete protection: 
# DELETE_PASSWORD → set the password that will be required to delete created systematic reviews

# Example:
# DELETE_PASSWORD="1qyu26rr"

DELETE_PASSWORD = "{create_password}"